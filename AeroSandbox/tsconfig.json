{
	"compilerOptions": {
		"target": "ESNext",
		"moduleResolution": "bundler",
		"module": "ESNext",
		"baseUrl": "./",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"sourceMap": true,
		"paths": {
			"$aero/*": ["../../*"],
			"$src/*": ["src/*"],
			"$sandbox/*": ["src/sandboxers/*"],
			"$apis/*": ["src/apis/*"],
			"$cors/*": ["src/security/cors/*"],
			"$fetchUtil": ["../aeroSW/src/fetchHandlers/util/*"],
			"$fetchSubsystems": ["../aeroSW/src/fetchHandlers/subsystems/*"],
			"$injPreprocessors": ["src/sandboxers/JS/preprocessors/*"],
			"$corsIsolation": ["../aeroSW/src/fetchHandlers/isolation/*"],
			"$util/*": ["src/util/*"],
			"$shared/*": ["src/shared/*"],
			"$types/*": ["types/*"],
			"$interceptorUtil/*": ["src/interceptors/util/*"],
			"$types/apiInterceptors": ["types/apiInterceptors.d.ts"]
		},
		"types": ["@types/websql", "@types/node", "@types/glob"],
		"allowImportingTsExtensions": true,
		"noEmit": true
	},
	"include": [
		"rspack.config.ts",
		"src/**/*.ts",
		"types/**/*.d.ts",
		"src/defaultConfig.js",
		"../aeroSW/src/this/util/getClientURLAeroWrapper.ts",
		"../aeroSW/src/this/util/getClientURL.ts",
		"../aeroSW/types/globals.d.ts",
		"build/**/*.ts"
	]
}
