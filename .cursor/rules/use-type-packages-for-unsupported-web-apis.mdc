---
description: Prioritize using @types on NPM for deprecated or experimental Web APIs instead of making your own
globs: ["**/*.ts", "**/*.d.ts"]
---

Don't try to invent your own types for Web APIs that are unsupported by dom.d.ts, rather do your research and look on NPM first to try to find types like these already implemented and try to incorporate them into the codebase.

Good:
```ts
...

declare global {
	class ContentIndex {
		add(data: { url: string }): Promise<void>;
	}
	interface Window {
		ContentIndex: typeof ContentIndex;
	}
}

/**
 * Content Index API interceptor that handles content indexing operations
 * This interceptor ensures all URLs are properly rewritten through the sandbox
 */
export default [
	{
		proxifiedObj: Proxy.revocable(window.ContentIndex, {
			apply(target, that, args) {
				const [data] = args as [{ url: string }];

				if (data?.url) {
					data.url = rewriteSrc(data.url);
				}

				return Reflect.apply(target, that, args);
			}
		}),
		globalProp: "window.ContentIndex",
		exposedContexts: ExposedContextsEnum.window
	}
] as const satisfies readonly [APIInterceptor];
```

