{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "noEmit": true
  },
  "include": [
    "./AeroSandbox/types/**/*.d.ts",
    "./aeroSW/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/dist"
  ]
} 